---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource-variable/inter";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "Developer Marketing Community"
  : "Developer Marketing Community - 2.5K+ API marketing experts on Slack";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script async src="https://cdn.splitbee.io/sb.js"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description="Slack community with 2.5K+ experts in developer marketing, developer tooling, and APIs"
      canonical={canonicalURL}
      twitter={{
        creator: "@gunnyganatra",
        site: "@gunnyganatra",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Developer Marketing Community`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Developer Marketing Community",
        },
      }}
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Developer Marketing Community",
      "url": "https://marketingto.dev",
      "description": "Slack community with 2,000+ experts in developer marketing, developer tooling, and APIs",
      "sameAs": [
        "https://twitter.com/gunnyganatra",
        "https://twitter.com/jczakon",
        "https://twitter.com/fmerian",
        "https://www.linkedin.com/in/ophirprusak",
        "https://devmarketingcommunity.slack.com"
      ]
    })} />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
