---
import { Image } from "astro:assets";
import heroImage from "assets/ballmer.png";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16 md:mt-24 pb-16">
  <div class="py-6 md:order-1 hidden md:block md:flex md:items-center md:justify-center">
    <Image
      src={heroImage}
      alt="Ballmer Developers"
      width={400}
      loading="eager"
    />
  </div>
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter leading-[1.05]">
      Developers! Developers! Developers!
    </h1>
    <p class="text-lg mt-4 text-slate-500 max-w-xl leading-relaxed">
      Join 2.5K+ passionate marketers working in API marketing, developer tooling, or actively marketing to developers.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="https://go.marketingto.dev/join"
        target="_blank"
        class="flex gap-1 items-center justify-center"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name="bx:bxs-envelope" />

        Request an invite
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href="https://go.marketingto.dev/slack"
        class="flex gap-1 items-center justify-center"
        target="_blank">
        <Icon class="text-black w-4 h-4" name="bx:bxl-slack" />
        Log in
      </Link>
    </div>
    <div>
      <p class="text-sm text-slate-400 mt-8">
        <a
          href="/code"
          class="hover:underline">
          Code of Conduct →
        </a>
      </p>
    </div>
  </div>
</main>
