---
const { align = "center" } = Astro.props;
---

<div class:list={["grid md:grid-cols-1 mx-auto max-w-4xl mt-16", align === "left" ? "text-left" : "text-center"]}>
  <h1 class="text-3xl lg:text-4xl font-bold lg:tracking-tight text-gray-900">
    <slot name="title">Title</slot>
  </h1>
  <p class="text-base lg:text-lg mt-3 text-slate-500 max-w-2xl mx-auto">
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
