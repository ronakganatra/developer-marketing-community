---
import Sectionhead from "@components/sectionhead.astro";

const features = [
  {
    title: "Developer marketing only",
    description:
      "From companies like Algolia, PostHog, and Kong, we're actively discussing relevant API marketing topics. No fluff. No noise.",
  },
  {
    title: "Globally distributed",
    description:
      "With members spread across from the West Coast to New Zealand, there's always someone in your time zone to chat with.",
  },
  {
    title: "Actionable experiences",
    description:
      "With expertise in SEO, CRM, PMM, GTM, and everything in between, there's always someone willing to share their insights.",
  },
];
---

<section class="bg-gray-50 py-20">
  <div class="max-w-4xl mx-auto px-5">
    <Sectionhead>
      <Fragment slot="title">Be a smarter developer marketer.</Fragment>
      <Fragment slot="desc">We're all about sharing, asking, and supporting one another to level up our dev marketing chops.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-3 gap-5 mt-12">
      {
        features.map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-gray-200 transition-all duration-200">
            <h3 class="font-semibold text-lg text-gray-900">{item.title}</h3>
            <p class="text-slate-500 mt-2 leading-relaxed text-sm">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
